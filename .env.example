# App Store Connect API key for TestFlight uploads.
# Copy this file to .env and fill in the values (the .env file is gitignored).
#
# Create a key at: https://appstoreconnect.apple.com/access/api
# Role needed: Admin or App Manager.

API_KEY_ID=YOUR_KEY_ID
API_ISSUER_ID=YOUR_ISSUER_ID

# Absolute path to the downloaded .p8 file.
# The filename is typically: AuthKey_YOURKEYID.p8
API_KEY_PATH=/absolute/path/to/AuthKey_YOURKEYID.p8

# Cloudflare Pages project for `make deploy-docs`. Authenticate Wrangler once
# with `npx wrangler login`. Deploy from an up-to-date main so the committed
# catalog JSON in dist/ matches what's live.
CF_PAGES_PROJECT=grypd-catalog
